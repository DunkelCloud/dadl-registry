      pagination: none

    reject_carrierfac:
      method: POST
      path: /carrierfac/{id}/reject
      access: admin
      description: "Reject a pending carrier-facility presence (facility-owner / staff action)."
      params:
        id: { type: integer, in: path, required: true, description: "carrierfac id." }
      response:
        result_path: "$.data"
      pagination: none

