        result_path: "$.data"
      pagination: none

    update_carrierfac:
      method: PUT
      path: /carrierfac/{id}
      access: write
      description: "Update a carrier-facility presence (partial). Repoints carrier_id / fac_id."
      params:
        id: { type: integer, in: path, required: true, description: "carrierfac id." }
        carrier_id: { type: integer, in: body }
        fac_id: { type: integer, in: body }
      response:
        result_path: "$.data"
      pagination: none

    delete_carrierfac:
      method: DELETE
      path: /carrierfac/{id}
      access: dangerous
      description: "Soft-delete a carrier-facility presence (status='deleted')."
      params:
        id: { type: integer, in: path, required: true, description: "carrierfac id." }
      pagination: none

    approve_carrierfac:
      method: POST
      path: /carrierfac/{id}/approve
      access: admin
      description: "Approve a pending carrier-facility presence (facility-owner / staff action)."
      params:
        id: { type: integer, in: path, required: true, description: "carrierfac id." }
      response:
