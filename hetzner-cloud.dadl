        id: { type: integer, in: path, required: true }
        name: { type: string, in: body }
        labels: { type: object, in: body }
      pagination: none

    delete_certificate:
      method: DELETE
      path: /certificates/{id}
      access: dangerous
      description: "Delete a certificate"
      params:
        id: { type: integer, in: path, required: true }
      pagination: none

