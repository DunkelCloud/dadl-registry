    list_module_bays:
      method: GET
      path: /dcim/module-bays/
      access: read
      description: "List module bays (slots on a device that accept modules)"
      params:
        device: { type: string, in: query }
        device_id: { type: integer, in: query }
        name: { type: string, in: query }
        q: { type: string, in: query }
