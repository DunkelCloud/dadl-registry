    # ──────────────────────────────────────────────

    get_system:
      method: GET
      path: /system
      access: read
      description: "Get system overview: node ID, hostname, version, lifecycle, LB status, timezone, OS info."
      response:
        result_path: "$"
      pagination: none

    get_system_stats:
      method: GET
      path: /system/stats
      access: read
      description: "Get node statistics (JVM memory, OS, process info)."
      response:
        result_path: "$"
      pagination: none

    get_throughput:
      method: GET
      path: /system/throughput
      access: read
      description: "Get current message throughput (messages per second)."
      response:
        result_path: "$"
      pagination: none

    get_total_message_count:
      method: GET
      path: /count/total
      access: read
      description: "Get the total number of messages stored."
      response:
        result_path: "$"
      pagination: none

    list_message_fields:
      method: GET
      path: /system/fields
      access: read
      description: "List all known message field names across all indices."
      response:
        result_path: "$.fields"
      pagination: none

    list_system_permissions:
      method: GET
      path: /system/permissions
      access: admin
