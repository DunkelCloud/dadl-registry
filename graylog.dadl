    resume_processing:
      method: POST
      path: /system/processing/resume
      access: admin
      description: "Resume message processing on this node."

    get_message_processor_config:
      method: GET
      path: /system/messageprocessors/config
      access: admin
      description: "Get message processor ordering and configuration."
      response:
        result_path: "$"
      pagination: none

    update_message_processor_config:
      method: PUT
      path: /system/messageprocessors/config
      access: admin
      description: "Update message processor ordering."
      params:
        processor_order: { type: array, in: body, required: true, description: "Ordered array of processor class names" }
        disabled_processors: { type: array, in: body }
      response:
        result_path: "$"
      pagination: none

